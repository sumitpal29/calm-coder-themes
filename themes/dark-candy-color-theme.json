  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#666655",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Documentation",
      "scope": ["comment.block.documentation", "comment.line.double-slash.documentation"],
      "settings": {
        "foreground": "#666655",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f8edb5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#f8edb5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#96eb99"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#2bb8b8"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": {
        "foreground": "#ffa053"
      }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#c98ad3"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.language", "variable.other.constant"],
      "settings": {
        "foreground": "#ffa053"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": {
        "foreground": "#D4D2C0"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter", "meta.function.parameter"],
      "settings": {
        "foreground": "#a0a8d0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Name",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": {
        "foreground": "#f8edb5"
      }
    },
    {
      "name": "Class / Type Name",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.class"
      ],
      "settings": {
        "foreground": "#c98ad3"
      }
    },
    {
      "name": "Interface",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#2bb8b8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type Annotation",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#c98ad3"
      }
    },
    {
      "name": "Object Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6ba3e0"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "keyword.operator.arithmetic", "keyword.operator.comparison"],
      "settings": {
        "foreground": "#f8edb5"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#666655"
      }
    },
    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": {
        "foreground": "#ffa053"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c98ad3"
      }
    },
    {
      "name": "HTML Attribute Value",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": {
        "foreground": "#96eb99"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": {
        "foreground": "#6ba3e0"
      }
    },
    {
      "name": "CSS Value",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": {
        "foreground": "#96eb99"
      }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#ffa053"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#f8edb5"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": {
        "foreground": "#f8edb5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#D4D2C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#D4D2C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link.description.markdown"],
      "settings": {
        "foreground": "#6ba3e0"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#2bb8b8"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#f8edb5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import / Module path",
      "scope": ["string.quoted.double.import", "string.quoted.single.import", "variable.other.module"],
      "settings": {
        "foreground": "#96eb99"
      }
    },
    {
      "name": "Built-in / Support",
      "scope": ["support.variable", "support.constant", "support.function.builtin"],
      "settings": {
        "foreground": "#2bb8b8"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#ff6b6b"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#666655",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#D4D2C0",
    "class": "#c98ad3",
    "enum": "#c98ad3",
    "interface": { "foreground": "#2bb8b8", "italic": true },
    "struct": "#c98ad3",
    "typeParameter": { "foreground": "#2bb8b8", "italic": true },
    "type": "#c98ad3",
    "function": "#f8edb5",
    "member": "#6ba3e0",
    "method": "#f8edb5",
    "macro": "#f8edb5",
    "variable": "#D4D2C0",
    "parameter": { "foreground": "#a0a8d0", "italic": true },
    "property": "#6ba3e0",
    "enumMember": "#ffa053",
    "event": "#f8edb5",
    "decorator": { "foreground": "#f8edb5", "italic": true },
    "label": "#f8edb5",
    "keyword": { "foreground": "#f8edb5", "bold": true },
    "modifier": { "foreground": "#f8edb5", "bold": true },
    "comment": { "foreground": "#666655", "italic": true },
    "string": "#96eb99",
    "number": "#ffa053",
    "operator": "#f8edb5",
    "regexp": "#2bb8b8"
  }
}
