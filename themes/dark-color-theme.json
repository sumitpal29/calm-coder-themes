  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4b5563",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#93c5fd",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.template", "string.quoted"],
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "name": "String escape / regex",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "name": "Boolean / Null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "variable.other.constant"],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f9fafb"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#9ca3af",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Class / Type",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "Interface",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#22d3ee",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key"],
      "settings": {
        "foreground": "#bfdbfe"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#9ca3af"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#6b7280"
      }
    },
    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#f87171"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#bfdbfe"
      }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#f87171"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#93c5fd"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#93c5fd",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#f9fafb",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Built-in / Support",
      "scope": ["support.variable", "support.function.builtin"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#f9fafb",
        "background": "#b91c1c"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#818cf8",
    "interface": { "foreground": "#22d3ee", "italic": true },
    "type": "#818cf8",
    "function": "#fbbf24",
    "method": "#fbbf24",
    "variable": "#f9fafb",
    "parameter": { "foreground": "#9ca3af", "italic": true },
    "property": "#bfdbfe",
    "enumMember": "#f472b6",
    "decorator": { "foreground": "#fbbf24", "italic": true },
    "string": "#34d399",
    "number": "#f472b6",
    "keyword": { "foreground": "#93c5fd", "bold": true },
    "comment": { "foreground": "#4b5563", "italic": true }
  }
}
