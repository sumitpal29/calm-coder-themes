  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9ca3af",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1d4ed8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.template", "string.quoted"],
      "settings": {
        "foreground": "#16a34a"
      }
    },
    {
      "name": "String escape / regex",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ea580c"
      }
    },
    {
      "name": "Boolean / Null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#1f2937"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#4b5563",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "name": "Class / Type",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "Interface",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#0891b2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key"],
      "settings": {
        "foreground": "#374151"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#4b5563"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#9ca3af"
      }
    },
    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#dc2626"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#374151"
      }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#dc2626"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#1d4ed8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#2563eb"
      }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#d97706",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#7c3aed",
    "interface": { "foreground": "#0891b2", "italic": true },
    "type": "#7c3aed",
    "function": "#1d4ed8",
    "method": "#1d4ed8",
    "variable": "#1f2937",
    "parameter": { "foreground": "#4b5563", "italic": true },
    "property": "#374151",
    "enumMember": "#ea580c",
    "decorator": { "foreground": "#d97706", "italic": true },
    "string": "#16a34a",
    "number": "#ea580c",
    "keyword": { "foreground": "#1d4ed8", "bold": true },
    "comment": { "foreground": "#9ca3af", "italic": true }
  }
}
