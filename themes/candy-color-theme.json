  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#a8a690",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Documentation",
      "scope": ["comment.block.documentation", "comment.line.double-slash.documentation"],
      "settings": {
        "foreground": "#a8a690",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8b6914",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#8b6914",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#1a9090"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": {
        "foreground": "#c44000"
      }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#6b4cb5"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.language", "variable.other.constant"],
      "settings": {
        "foreground": "#c44000"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": {
        "foreground": "#616163"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter", "meta.function.parameter"],
      "settings": {
        "foreground": "#5a5a80",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Name",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": {
        "foreground": "#7a5c00"
      }
    },
    {
      "name": "Class / Type Name",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.class"
      ],
      "settings": {
        "foreground": "#6b4cb5"
      }
    },
    {
      "name": "Interface",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#1a9090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type Annotation",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#6b4cb5"
      }
    },
    {
      "name": "Object Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#4a5480"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "keyword.operator.arithmetic", "keyword.operator.comparison"],
      "settings": {
        "foreground": "#8b6914"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#888870"
      }
    },
    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": {
        "foreground": "#c44000"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#6b4cb5"
      }
    },
    {
      "name": "HTML Attribute Value",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": {
        "foreground": "#4a5480"
      }
    },
    {
      "name": "CSS Value",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "name": "CSS Selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#c44000"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#8b6914"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": {
        "foreground": "#7a5c00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#4a4a2c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#616163",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link.description.markdown"],
      "settings": {
        "foreground": "#4a7cc0"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#1a9090"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#b8860b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import / Module path",
      "scope": ["string.quoted.double.import", "string.quoted.single.import", "variable.other.module"],
      "settings": {
        "foreground": "#2d7a2d"
      }
    },
    {
      "name": "Built-in / Support",
      "scope": ["support.variable", "support.constant", "support.function.builtin"],
      "settings": {
        "foreground": "#1a9090"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#ffffff",
        "background": "#c0392b"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#616163",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#616163",
    "class": "#6b4cb5",
    "enum": "#6b4cb5",
    "interface": { "foreground": "#1a9090", "italic": true },
    "struct": "#6b4cb5",
    "typeParameter": { "foreground": "#1a9090", "italic": true },
    "type": "#6b4cb5",
    "function": "#7a5c00",
    "member": "#4a5480",
    "method": "#7a5c00",
    "macro": "#b8860b",
    "variable": "#616163",
    "parameter": { "foreground": "#5a5a80", "italic": true },
    "property": "#4a5480",
    "enumMember": "#c44000",
    "event": "#b8860b",
    "decorator": { "foreground": "#b8860b", "italic": true },
    "label": "#8b6914",
    "keyword": { "foreground": "#8b6914", "bold": true },
    "modifier": { "foreground": "#8b6914", "bold": true },
    "comment": { "foreground": "#a8a690", "italic": true },
    "string": "#2d7a2d",
    "number": "#c44000",
    "operator": "#8b6914",
    "regexp": "#1a9090"
  }
}
